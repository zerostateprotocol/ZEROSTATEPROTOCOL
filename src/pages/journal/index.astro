---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import PostCard from '../../components/journal/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('journal', ({ data }) => !data.draft);
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  title="Security Research Journal | Brahma — Zero State Protocol"
  description="Thoughts, research, and technical deep-dives into application security."
>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="flex flex-col md:flex-row md:justify-between md:items-end mb-12">
      <SectionHeader label="// DISPATCHES" heading="LATEST FROM THE FIELD" class="mb-4 md:mb-0" />
      <a href={`${import.meta.env.BASE_URL}rss.xml`} class="inline-flex items-center gap-2 text-brand-purple hover:text-brand-purpleLight font-space tracking-widest text-sm transition-colors mb-2">
        <iconify-icon icon="mingcute:rss-2-fill"></iconify-icon> RSS FEED
      </a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map(post => (
        <PostCard post={post} />
      ))}
    </div>
  </main>
</BaseLayout>
