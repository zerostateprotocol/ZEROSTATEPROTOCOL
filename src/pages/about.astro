---
import BaseLayout from '../components/layout/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import ContactForm from '../components/about/ContactForm.astro';
import RetroCard from '../components/ui/RetroCard.astro';

const personSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Brahma",
  "url": "https://brahma.dev",
  "sameAs": [
    "https://twitter.com/brahma",
    "https://github.com/brahma-sec"
  ],
  "jobTitle": "Security Researcher & Bug Bounty Hunter",
  "knowsAbout": ["Cybersecurity", "Bug Bounty", "Web Security", "Exploit Development"]
});

const skills = [
  {
    id: 'web-security',
    label: 'WEB_SEC',
    heading: 'Web Security',
    icon: 'mingcute:web-line',
    desc: 'XSS, SQLi, SSRF, IDOR, deserialization, WAF bypass, and complex logic flaws in modern web stacks.',
    color: '#a855f7',
    glow: 'rgba(168,85,247,0.15)',
  },
  {
    id: 'api-security',
    label: 'API_SEC',
    heading: 'API Security',
    icon: 'mingcute:link-line',
    desc: 'REST & GraphQL attack surfaces, broken object-level auth, mass assignment, and JWT manipulation.',
    color: '#22c55e',
    glow: 'rgba(34,197,94,0.12)',
  },
  {
    id: 'web3-security',
    label: 'WEB3_SEC',
    heading: 'Web3 Security',
    icon: 'mingcute:cube-3d-line',
    desc: 'Smart contract auditing, reentrancy, flash loan exploits, and DeFi protocol vulnerability research.',
    color: '#eab308',
    glow: 'rgba(234,179,8,0.12)',
  },
  {
    id: 'android-security',
    label: 'ANDROID_SEC',
    heading: 'Android Security',
    icon: 'mingcute:android-2-line',
    desc: 'APK reversing, deep-link hijacking, exported component abuse, and traffic interception on mobile targets.',
    color: '#f43f5e',
    glow: 'rgba(244,63,94,0.12)',
  },
  {
    id: 'game-dev',
    label: 'GAME_DEV',
    heading: 'Game Development',
    icon: 'mingcute:gamepad-line',
    desc: 'Building interactive experiences with a hacker mindset — from game mechanics to cheat-resistant architectures.',
    color: '#c084fc',
    glow: 'rgba(192,132,252,0.12)',
  },
  {
    id: 'app-dev',
    label: 'APP_DEV',
    heading: 'App Development',
    icon: 'mingcute:code-line',
    desc: 'Full-stack and mobile app development with a security-first philosophy baked in from day one.',
    color: '#22c55e',
    glow: 'rgba(34,197,94,0.10)',
  },
];
---

<BaseLayout
  title="About Brahma | Zero State Protocol"
  description="Learn more about Brahma, an offensive security researcher and top-tier bug bounty hunter."
>
  <script type="application/ld+json" set:html={personSchema} slot="head" />
  
  <main class="max-w-4xl mx-auto px-4 py-24">
    <!-- Identity + Bio -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-24">
      <div class="md:col-span-1">
        <div class="aspect-square bg-brand-bgHover border-4 border-brand-border p-2 retro-shadow-lg mb-6">
          <div class="w-full h-full bg-brand-purple/20 flex flex-col items-center justify-center font-vhs text-brand-purple tracking-widest crt-lines gap-2">
            <iconify-icon icon="mingcute:ghost-fill" width="64" height="64"></iconify-icon>
            <span class="text-xl animate-pulse">NO_FACIAL_REC</span>
          </div>
        </div>
        
        <div class="font-space text-sm tracking-widest text-brand-purpleLight mb-4 font-bold border-b border-brand-border pb-2">IDENTIFICATION</div>
        <ul class="space-y-3 font-mono text-sm text-brand-textMuted">
          <li>ALIAS: Brahma</li>
          <li>CLASS: Hunter</li>
          <li>AFFILIATION: Independent</li>
          <li>STATUS: Active</li>
        </ul>
      </div>
      
      <div class="md:col-span-2 space-y-6 lg:pl-12">
        <SectionHeader label="// WHOAMI" heading="THE OPERATOR" class="mb-8" />
        
        <div class="prose prose-invert prose-purple max-w-none font-mono">
          <p>
            I am a full-time offensive security researcher and bug bounty hunter specializing in web application vulnerabilities, cloud infrastructure security, and undocumented exploit chains.
          </p>
          <p>
            The Zero State Protocol is a methodology: approaching every target with zero assumptions about its security posture. Where others see standard functionality, I look for logic flaws, edge cases in deserialization, and complex SSRF escalations.
          </p>
          <p>
            Currently holding multiple top 50 leaderboard positions across major bounty platforms. My research focuses on the intersection of cloud-native architecture, WAF bypass techniques, and subtle race conditions.
          </p>
        </div>
      </div>
    </div>

    <!-- Skill Tiles -->
    <div class="mb-24">
      <SectionHeader label="// CAPABILITIES" heading="SKILL MATRIX" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
        {skills.map((skill) => (
          <div
            class="skill-tile group relative border-2 border-brand-border bg-brand-bgCard p-6 retro-shadow transition-all duration-200 cursor-default"
            data-color={skill.color}
            data-glow={skill.glow}
          >
            <div class="accent-bar absolute top-0 left-0 right-0 h-[3px]" style={`background: ${skill.color};`}></div>

            <div
              class="w-12 h-12 border-2 border-brand-border flex items-center justify-center mb-4"
              style={`background: ${skill.glow};`}
            >
              <iconify-icon icon={skill.icon} width="24" height="24" style={`color: ${skill.color};`}></iconify-icon>
            </div>

            <div class="font-vhs text-xs tracking-widest mb-1" style={`color: ${skill.color};`}>
              {`// ${skill.label}`}
            </div>

            <h3 class="font-pixel text-sm text-brand-textPrimary mb-3 leading-snug">{skill.heading}</h3>

            <p class="font-mono text-xs text-brand-textMuted leading-relaxed">{skill.desc}</p>

            <div class="absolute bottom-3 right-3 font-pixel text-[8px] text-brand-textFaint opacity-60">
              [{skill.id.toUpperCase()}]
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Contact Form -->
    <div>
      <SectionHeader label="// COMM LINK" heading="DIRECT TRANSMISSION" />
      <ContactForm />
    </div>
  </main>
</BaseLayout>

<style>
  .skill-tile {
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .skill-tile:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0px #1a0a2e;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.skill-tile').forEach(tile => {
    const color = tile.dataset.color ?? '#a855f7';
    const glow  = tile.dataset.glow  ?? 'rgba(168,85,247,0.15)';
    tile.addEventListener('mouseenter', () => {
      tile.style.background    = glow;
      tile.style.borderColor   = color;
    });
    tile.addEventListener('mouseleave', () => {
      tile.style.background    = '';
      tile.style.borderColor   = '';
    });
  });
</script>
