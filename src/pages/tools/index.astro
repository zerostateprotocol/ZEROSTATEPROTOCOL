---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import ToolCard from '../../components/tools/ToolCard.astro';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');
---

<BaseLayout
  title="Security Tools & Resources | Brahma — Zero State Protocol"
  description="Open-source security tools, recon suites, and utility scripts crafted by Brahma."
>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <SectionHeader label="// ARSENAL" heading="HUNTER'S TOOLBOX" />
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-16 pt-8">
      {tools.map(tool => (
        <ToolCard post={tool} />
      ))}
    </div>
  </main>
</BaseLayout>
