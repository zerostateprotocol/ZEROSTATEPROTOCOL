---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import ArchiveItem from '../../components/archive/ArchiveItem.astro';
import { getCollection } from 'astro:content';

const archive = await getCollection('archive');
archive.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  title="Archive | Brahma — Zero State Protocol"
  description="The vault. All past transmissions, conference recaps, and notable entries."
>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <SectionHeader label="// VAULT" heading="THE ARCHIVE" />
    
    <div class="mt-12 bg-brand-bgCard pixel-border">
      {archive.map(entry => (
        <ArchiveItem post={entry} />
      ))}
    </div>
  </main>
</BaseLayout>
