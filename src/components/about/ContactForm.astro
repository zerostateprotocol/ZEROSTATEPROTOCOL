---
import RetroCard from '../ui/RetroCard.astro';
import RetroButton from '../ui/RetroButton.astro';
---
<RetroCard class="p-8">
  <form id="contact-form" class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="contact-name" class="block font-space text-xs tracking-widest text-brand-purpleDim mb-2">IDENTIFIER</label>
        <input type="text" id="contact-name" name="name" required class="w-full bg-brand-bg retro-input border-2 border-brand-border text-brand-textPrimary font-mono px-4 py-3 focus:outline-none focus:border-brand-purple transition-colors" placeholder="Name or Handle" />
      </div>
      <div>
        <label for="contact-email" class="block font-space text-xs tracking-widest text-brand-purpleDim mb-2">RETURN ADDRESS</label>
        <input type="email" id="contact-email" name="email" required class="w-full bg-brand-bg retro-input border-2 border-brand-border text-brand-textPrimary font-mono px-4 py-3 focus:outline-none focus:border-brand-purple transition-colors" placeholder="Email Address" />
      </div>
    </div>
    
    <div>
      <label for="contact-message" class="block font-space text-xs tracking-widest text-brand-purpleDim mb-2">TRANSMISSION DATA</label>
      <textarea id="contact-message" name="message" required rows="6" class="w-full bg-brand-bg retro-input border-2 border-brand-border text-brand-textPrimary font-mono px-4 py-3 focus:outline-none focus:border-brand-purple transition-colors" placeholder="Enter message..."></textarea>
    </div>
    
    <RetroButton type="submit" variant="primary" class="w-full">TRANSMIT</RetroButton>
  </form>
  
  <div id="contact-success" class="hidden mt-8 text-center p-6 bg-brand-bg border border-brand-green/30 dashed-border">
    <div class="font-pixel text-brand-green text-sm mb-4">TRANSMISSION SUCCESSFUL</div>
    <p class="font-mono text-brand-textMuted text-sm">Message received. I will review and respond securely.</p>
  </div>
</RetroCard>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('contact-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const emailInput = document.getElementById('contact-email') as HTMLInputElement;
    const nameInput = document.getElementById('contact-name') as HTMLInputElement;
    const messageInput = document.getElementById('contact-message') as HTMLTextAreaElement;
    
    const mailto = `mailto:hello@brahma.dev?subject=Message from ${encodeURIComponent(nameInput.value)}&body=${encodeURIComponent(messageInput.value)}`;
    window.location.href = mailto;
    
    form.reset();
    form.classList.add('hidden');
    if(successMsg) successMsg.classList.remove('hidden');
  });
</script>
