---
import RetroButton from '../ui/RetroButton.astro';

const year = new Date().getFullYear();
---
<footer class="bg-brand-bgDeep border-t-2 border-brand-border pt-16 pb-8 mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <div class="md:col-span-2 space-y-4">
        <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-3">
          <div class="w-8 h-8 bg-brand-textDim pixel-border flex items-center justify-center">
            <span class="font-pixel text-brand-bg text-[10px]">ZS</span>
          </div>
          <span class="font-pixel text-brand-textMuted text-xs tracking-widest">ZERO STATE PROTOCOL</span>
        </a>
        <p class="font-mono text-sm text-brand-textFaint">
          Security research, bug bounty writeups, and tools from the bleeding edge.
        </p>
      </div>
      
      <div>
        <h3 class="font-space text-brand-purpleLight font-bold tracking-widest mb-4">LINKS</h3>
        <ul class="space-y-2 font-mono text-sm text-brand-textMuted">
          <li><a href={`${import.meta.env.BASE_URL}/journal`} class="hover:text-brand-purple transition-colors">Journal</a></li>
          <li><a href={`${import.meta.env.BASE_URL}/bounties`} class="hover:text-brand-purple transition-colors">Bounties</a></li>
          <li><a href={`${import.meta.env.BASE_URL}/tools`} class="hover:text-brand-purple transition-colors">Arsenal</a></li>
          <li><a href={`${import.meta.env.BASE_URL}/archive`} class="hover:text-brand-purple transition-colors">Archive</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-space text-brand-purpleLight font-bold tracking-widest mb-4">SOCIAL</h3>
        <ul class="space-y-2 font-mono text-sm text-brand-textMuted">
          <li><a href="#" class="hover:text-brand-purple transition-colors flex items-center gap-2"><iconify-icon icon="ri:twitter-x-fill"></iconify-icon> Twitter / X</a></li>
          <li><a href="#" class="hover:text-brand-purple transition-colors flex items-center gap-2"><iconify-icon icon="ri:github-fill"></iconify-icon> GitHub</a></li>
          <li><a href="#" class="hover:text-brand-purple transition-colors flex items-center gap-2"><iconify-icon icon="ri:key-fill"></iconify-icon> PGP Key</a></li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-brand-borderDim pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-mono text-brand-textFaint">
      <p>&copy; {year} Brahma. All rights reserved.</p>
      <p class="font-vhs text-lg">SYSTEM OFFLINE</p>
    </div>
  </div>
</footer>
