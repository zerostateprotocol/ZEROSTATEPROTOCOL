---
interface Props {
  filename?: string;
  lines: Array<{ text: string; color?: string; blink?: boolean }>;
  class?: string;
}

const { filename = 'terminal.exe', lines, class: className = '' } = Astro.props;
---
<div class={`bg-[#000000] pixel-border retro-shadow p-0.5 animate-float flex flex-col ${className}`}>
  {/* Header Bar */}
  <div class="bg-brand-bgHover border-b-2 border-brand-border p-2 flex items-center justify-between">
    <div class="flex space-x-2">
      <div class="w-3 h-3 bg-brand-red rounded-full"></div>
      <div class="w-3 h-3 bg-brand-yellow rounded-full"></div>
      <div class="w-3 h-3 bg-brand-green rounded-full"></div>
    </div>
    <div class="font-vhs text-brand-textMuted text-lg tracking-widest">{filename}</div>
    <div class="w-10"></div> {/* Spacer for alignment */}
  </div>
  
  {/* Body */}
  <div class="p-4 font-mono text-sm sm:text-base leading-relaxed flex-grow overflow-hidden">
    {lines.map((line, idx) => (
      <div class={`
        ${line.color || 'text-brand-green'} 
        ${line.blink || idx === lines.length - 1 ? 'cursor-blink' : ''}
      `}>
        {line.text}
      </div>
    ))}
  </div>
</div>
