---
interface Props {
  size?: string;
  class?: string;
}
const { size = 'w-10 h-10', class: className = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<img
  src={`${base}logo.png`}
  alt="Zero State Protocol"
  class={`${size} ${className} inline-block shrink-0 object-contain`}
/>
