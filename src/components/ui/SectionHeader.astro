---
interface Props {
  label: string;
  heading: string;
  class?: string;
}

const { label, heading, class: className = '' } = Astro.props;
---
<div class={`mb-12 ${className}`}>
  <div class="inline-block bg-brand-border pixel-border retro-shadow px-4 py-1 mb-6">
    <span class="font-vhs text-2xl text-brand-purpleLight tracking-widest">{label}</span>
  </div>
  <h2 class="font-pixel text-2xl md:text-3xl text-brand-textPrimary leading-tight">{heading}</h2>
</div>
