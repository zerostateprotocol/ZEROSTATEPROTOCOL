---
interface Props {
  variant?: 'primary' | 'ghost';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: any;
}

const { variant = 'primary', href, type, class: className = '', ...rest } = Astro.props;

const baseStyles = "retro-btn px-6 py-3 font-space uppercase tracking-wider inline-block text-center cursor-pointer";
const variantStyles = variant === 'primary' 
  ? "bg-brand-purple text-brand-bg pixel-border" 
  : "bg-brand-bgHover text-brand-purpleLight border-brand-purpleDim pixel-border";

const classes = `${baseStyles} ${variantStyles} ${className}`;
---
{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}
