---
// Kit form ID from the embed code
const KIT_FORM_ID = "9347398";
const KIT_UID = "0d84cc5377";
---

<!-- Overlay -->
<div
  id="newsletter-modal"
  class="fixed inset-0 z-[999] flex items-center justify-center p-4 hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <!-- Backdrop -->
  <div id="modal-backdrop" class="absolute inset-0 bg-brand-bg/80 backdrop-blur-sm"></div>

  <!-- Modal Box -->
  <div class="relative z-10 w-full max-w-lg bg-brand-bgCard pixel-border retro-shadow border-2 border-brand-purple">

    <!-- Top bar -->
    <div class="flex items-center justify-between px-5 py-3 border-b-2 border-brand-border bg-brand-bgHover">
      <div class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-brand-red inline-block"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-400 inline-block"></span>
        <span class="w-3 h-3 rounded-full bg-brand-green inline-block"></span>
      </div>
      <span class="font-space text-xs tracking-widest text-brand-textFaint">comm_link.exe</span>
      <button
        id="modal-close"
        class="text-brand-textFaint hover:text-brand-textPrimary transition-colors cursor-pointer"
        aria-label="Close"
      >
        <iconify-icon icon="mingcute:close-fill" width="18"></iconify-icon>
      </button>
    </div>

    <!-- Body -->
    <div class="p-8">
      <!-- Header -->
      <div class="mb-6 text-center">
        <div class="inline-block bg-brand-border pixel-border px-3 py-1 mb-4">
          <span class="font-space text-xs tracking-widest text-brand-purpleLight">// COMM LINK</span>
        </div>
        <h2 id="modal-title" class="font-pixel text-xl text-brand-textPrimary mb-3 leading-relaxed">
          JOIN THE NETWORK
        </h2>
        <p class="font-mono text-sm text-brand-textMuted leading-relaxed">
          Get notified on new 0-days, writeups &amp; research.<br/>No spam. Just signal.
        </p>
      </div>

      <!-- Kit Form — styled to match site theme -->
      <div id="kit-form-wrapper">
        <form
          action={`https://app.kit.com/forms/${KIT_FORM_ID}/subscriptions`}
          method="post"
          id="zsp-newsletter-form"
          class="space-y-4"
        >
          <!-- Honeypot -->
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

          <div>
            <label for="kit-email" class="block font-space text-xs tracking-widest text-brand-purpleDim mb-2">
              SECURE ENDPOINT
            </label>
            <input
              type="email"
              id="kit-email"
              name="email_address"
              required
              placeholder="you@domain.com"
              class="w-full bg-brand-bg border-2 border-brand-border text-brand-textPrimary font-mono px-4 py-3 focus:outline-none focus:border-brand-purple transition-colors placeholder:text-brand-textFaint text-sm tracking-wider"
            />
            <div id="kit-email-error" class="hidden mt-2 font-mono text-xs text-brand-red animate-pulse">
              INVALID EMAIL FORMAT DETECTED
            </div>
          </div>

          <button
            type="submit"
            id="kit-submit-btn"
            class="retro-btn w-full px-6 py-3 font-space uppercase tracking-wider bg-brand-purple text-brand-bg pixel-border hover:bg-brand-purpleLight transition-colors cursor-pointer flex items-center justify-center gap-2"
          >
            <span id="kit-btn-text">ESTABLISH CONNECTION</span>
            <span id="kit-btn-spinner" class="hidden">
              <iconify-icon icon="mingcute:loading-fill" width="16" class="animate-spin"></iconify-icon>
            </span>
          </button>
        </form>

        <!-- Success state -->
        <div id="kit-success" class="hidden text-center py-4">
          <div class="font-pixel text-brand-green text-sm mb-3 leading-relaxed">
            CONNECTION SECURED
          </div>
          <p class="font-mono text-brand-textMuted text-xs leading-relaxed">
            Check your email to confirm.<br/>Welcome to the network.
          </p>
          <div class="mt-4 font-mono text-xs text-brand-textFaint border border-brand-border px-4 py-3 bg-brand-bgHover">
            <span class="text-brand-green">$</span> subscription --status<br/>
            <span class="text-brand-green">▶</span> PENDING_CONFIRMATION
          </div>
        </div>
      </div>

      <p class="mt-4 text-center font-mono text-xs text-brand-textFaint">
        Unsubscribe at any time. No BS.
      </p>
    </div>
  </div>
</div>

<script define:vars={{ KIT_FORM_ID }}>
  const modal      = document.getElementById('newsletter-modal');
  const backdrop   = document.getElementById('modal-backdrop');
  const closeBtn   = document.getElementById('modal-close');
  const form       = document.getElementById('zsp-newsletter-form');
  const emailInput = document.getElementById('kit-email');
  const emailError = document.getElementById('kit-email-error');
  const submitBtn  = document.getElementById('kit-submit-btn');
  const btnText    = document.getElementById('kit-btn-text');
  const btnSpinner = document.getElementById('kit-btn-spinner');
  const success    = document.getElementById('kit-success');
  const formWrapper = document.getElementById('kit-form-wrapper');

  function openModal() {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(() => emailInput?.focus(), 100);
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  // Wire all subscribe triggers (nav button + any data-newsletter-trigger)
  function wireButtons() {
    document.querySelectorAll('[data-newsletter-trigger]').forEach(el => {
      el.addEventListener('click', (e) => { e.preventDefault(); openModal(); });
    });
  }
  wireButtons();

  backdrop?.addEventListener('click', closeModal);
  closeBtn?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    if (!emailRegex.test(email)) {
      emailError.classList.remove('hidden');
      return;
    }
    emailError.classList.add('hidden');

    // Show spinner
    btnText.textContent = 'CONNECTING...';
    btnSpinner.classList.remove('hidden');
    submitBtn.disabled = true;

    try {
      const formData = new FormData(form);
      await fetch(form.action, {
        method: 'POST',
        body: formData,
        mode: 'no-cors', // Kit doesn't support CORS from browser, use no-cors
      });
      // no-cors means we can't read response, but submission goes through
      form.classList.add('hidden');
      success.classList.remove('hidden');
    } catch (err) {
      // Fallback: submit normally
      form.submit();
    }
  });
</script>
