---
import TerminalWindow from '../ui/TerminalWindow.astro';
import StatBlock from '../ui/StatBlock.astro';
import RetroButton from '../ui/RetroButton.astro';
import ZSPLogo from '../ui/ZSPLogo.astro';

const terminalLines = [
  { text: 'brahma@zsp:~$ ./recon.sh --target megacorp.com', color: 'text-brand-textPrimary' },
  { text: '[+] Starting extensive reconnaissance...', color: 'text-brand-green' },
  { text: '[*] Enumerating subdomains via Passive Sources...', color: 'text-brand-textMuted' },
  { text: '[+] Found 4,204 active subdomains.', color: 'text-brand-green' },
  { text: '[*] Scanning for open ports and services...', color: 'text-brand-textMuted' },
  { text: '[!] VULNERABILITY DETECTED: CVE-2023-XXXXX on admin.megacorp.com', color: 'text-brand-red' },
  { text: '[+] Initiating exploit payload delivery...', color: 'text-brand-yellow' },
  { text: 'root@admin:~# ', color: 'text-brand-textPrimary' }
];
---
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 min-h-[80vh] flex items-center">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center w-full">
    
    <div class="space-y-8">
      <div class="inline-block bg-brand-bgHover border-l-4 border-brand-red px-4 py-2 pixel-border">
        <span class="font-vhs text-brand-red text-xl tracking-widest animate-pulse">STATUS: HUNTER</span>
      </div>
      
      <h1 class="font-pixel text-4xl md:text-5xl lg:text-6xl text-brand-textPrimary leading-tight">
        HACK <br/>
        <span class="text-brand-purple">THE</span> <br/>
        PLANET
      </h1>
      
      <p class="font-mono text-lg text-brand-textMuted max-w-lg leading-relaxed">
        Offensive security researcher and top-tier bug bounty hunter. Exposing vulnerabilities before the adversaries find them.
      </p>
      
      <div class="flex flex-wrap gap-4 pt-4">
        <RetroButton href={`${import.meta.env.BASE_URL}bounties`} variant="primary">READ WRITEUPS</RetroButton>
        <RetroButton href={`${import.meta.env.BASE_URL}about`} variant="ghost">ABOUT BRAHMA</RetroButton>
      </div>
      
      <div class="grid grid-cols-2 gap-4 pt-12">
        <StatBlock value="50+" label="Bounties" />
        <StatBlock value="$30K+" label="Awarded" />
      </div>
    </div>
    
    <div class="hidden lg:block relative">
      <!-- Purple glow blob -->
      <div class="absolute -inset-4 bg-brand-purple/20 blur-3xl rounded-full"></div>
      <!-- ZSP logo as large glowing watermark, centered behind terminal -->
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-0">
        <div style="filter: invert(0%) sepia(0%) saturate(0%) hue-rotate(0deg) brightness(0.4) contrast(1);">
          <ZSPLogo size="w-80 h-80" class="opacity-10" />
        </div>
      </div>
      <TerminalWindow lines={terminalLines} class="relative z-10" />
    </div>

  </div>
</section>