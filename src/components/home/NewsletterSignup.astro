---
import SectionHeader from '../ui/SectionHeader.astro';
import RetroCard from '../ui/RetroCard.astro';
import RetroButton from '../ui/RetroButton.astro';
---
<div class="flex-1 lg:max-w-md w-full">
  <SectionHeader label="// COMM LINK" heading="JOIN NETWORK" />
  
  <RetroCard class="p-6 md:p-8">
    <p class="font-mono text-brand-textMuted mb-6 leading-relaxed">
      Get notified about new 0-days, vulnerability writeups, and security research directly to your inbox. No spam, just signal.
    </p>
    
    <form id="newsletter-form" class="space-y-4">
      <div>
        <label for="handle" class="block font-space text-xs tracking-widest text-brand-purpleDim mb-2">HANDLE (OPTIONAL)</label>
        <input type="text" id="handle" name="handle" class="w-full bg-brand-bg retro-input border-2 border-brand-border text-brand-textPrimary font-mono px-4 py-3 focus:outline-none focus:border-brand-purple transition-colors" placeholder="@username" />
      </div>
      
      <div>
        <label for="email" class="block font-space text-xs tracking-widest text-brand-purpleDim mb-2">SECURE ENDPOINT (EMAIL)</label>
        <input type="email" id="email" name="email" required class="w-full bg-brand-bg retro-input border-2 border-brand-border text-brand-textPrimary font-mono px-4 py-3 focus:outline-none focus:border-brand-purple transition-colors" placeholder="you@domain.com" />
        <div id="email-error" class="hidden text-brand-red font-mono text-xs mt-2 animate-pulse">INVALID EMAIL FORMAT DETECTED</div>
      </div>
      
      <RetroButton type="submit" variant="primary" class="w-full mt-4">ESTABLISH CONNECTION</RetroButton>
    </form>
    
    <div id="newsletter-success" class="hidden mt-6 text-center">
      <div class="font-pixel text-brand-green text-sm mb-2">CONNECTION SECURED</div>
      <p class="font-mono text-brand-textMuted text-xs">You are now on the distribution list.</p>
    </div>
  </RetroCard>
</div>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const errorMsg = document.getElementById('email-error');
  const successMsg = document.getElementById('newsletter-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    
    if (!emailRegex.test(emailInput.value)) {
      if(errorMsg) errorMsg.classList.remove('hidden');
      return;
    }
    
    if(errorMsg) errorMsg.classList.add('hidden');
    form.classList.add('hidden');
    if(successMsg) successMsg.classList.remove('hidden');
  });
</script>
