---
import RetroCard from '../ui/RetroCard.astro';
import RetroTag from '../ui/RetroTag.astro';

interface Props {
  post: any;
}

const { post } = Astro.props;
const { title, severity, date, bountyAmount } = post.data;
---
<a href={`${import.meta.env.BASE_URL}/bounties/${post.id}`} class="block group h-full">
  <RetroCard class="p-6 h-full flex flex-col space-y-4 transition-colors group-hover:border-brand-purpleDim">
    <div class="flex justify-between items-start">
      <RetroTag severity={severity} />
      {bountyAmount && <span class="font-pixel text-xs text-brand-green">${bountyAmount.toLocaleString()}</span>}
    </div>
    
    <h3 class="font-pixel text-sm md:text-base text-brand-textPrimary leading-relaxed group-hover:text-brand-purpleLight transition-colors">
      {title}
    </h3>
    
    <div class="mt-auto pt-4 flex justify-between items-center font-space text-xs text-brand-textFaint tracking-widest group-hover:text-brand-purple transition-colors">
      <span class="font-mono text-xs text-brand-textMuted group-hover:text-brand-purple">{new Date(date).toLocaleDateString()}</span>
      <span>→</span>
    </div>
  </RetroCard>
</a>
