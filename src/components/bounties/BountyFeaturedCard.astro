---
import RetroCard from '../ui/RetroCard.astro';
import RetroTag from '../ui/RetroTag.astro';

interface Props {
  post: any;
}

const { post } = Astro.props;
const { title, severity, bountyAmount, date, program, description } = post.data;
const href = `${import.meta.env.BASE_URL}bounties/${post.id}`;
---
<a href={href} class="block group lg:col-span-2">
  <RetroCard class="p-8 h-full flex flex-col md:flex-row gap-8 transition-colors group-hover:border-brand-purpleDim">
    <!-- left: content -->
    <div class="flex-1 space-y-4">
      <div class="flex flex-wrap gap-3 items-center">
        <RetroTag severity={severity} />
        <span class="font-mono text-sm text-brand-textMuted">{new Date(date).toLocaleDateString()}</span>
      </div>

      <h3 class="font-pixel text-xl md:text-2xl text-brand-textPrimary leading-tight group-hover:text-brand-purpleLight transition-colors">
        {title}
      </h3>

      <p class="font-mono text-brand-textMuted">{description}</p>

      <div class="pt-4">
        <span class="inline-block font-space text-xs tracking-widest text-brand-textFaint border border-brand-border px-4 py-2 group-hover:border-brand-purple group-hover:text-brand-purpleLight transition-colors">
          READ FULL REPORT →
        </span>
      </div>
    </div>

    <!-- right: program + payout panel -->
    <div class="md:w-64 bg-brand-bgDeep pixel-border p-6 flex flex-col justify-center space-y-6 shrink-0">
      <div>
        <div class="font-space text-xs text-brand-textFaint tracking-widest mb-1">PROGRAM</div>
        <div class="font-mono text-brand-textPrimary">{program}</div>
      </div>
      <div>
        <div class="font-space text-xs text-brand-textFaint tracking-widest mb-1">PAYOUT</div>
        <div class="font-pixel text-brand-green text-xl">${bountyAmount?.toLocaleString()}</div>
      </div>
    </div>
  </RetroCard>
</a>
