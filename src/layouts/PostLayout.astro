---
import BaseLayout from '../components/layout/BaseLayout.astro';
import RetroTag from '../components/ui/RetroTag.astro';

const { title, description, date, ogImage, tags = [], severity, bountyAmount, program, category } = Astro.props;
---
<BaseLayout title={title} description={description} ogImage={ogImage}>
  <main class="max-w-4xl mx-auto px-4 py-16">
    <div class="mb-12 border-b-2 border-brand-border pb-8">
      {severity && <RetroTag severity={severity} class="mb-4" />}
      <h1 class="font-pixel text-3xl md:text-4xl text-brand-textPrimary leading-tight mb-6">{title}</h1>
      
      <div class="flex flex-wrap gap-4 font-mono text-sm text-brand-textMuted md:items-center">
        {date && (
          <div class="flex items-center gap-2">
            <iconify-icon icon="mingcute:calendar-fill"></iconify-icon>
            {new Date(date).toLocaleDateString()}
          </div>
        )}
        {bountyAmount && (
          <div class="flex items-center gap-2 text-brand-green">
            <iconify-icon icon="mingcute:currency-dollar-2-fill"></iconify-icon>
            ${bountyAmount.toLocaleString()}
          </div>
        )}
        {program && (
          <div class="flex items-center gap-2">
            <iconify-icon icon="mingcute:building-3-fill"></iconify-icon>
            {program}
          </div>
        )}
      </div>

      {tags && tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {tags.map((tag: string) => (
            <span class="text-xs font-mono text-brand-purpleDim border border-brand-border px-2 py-1">#{tag}</span>
          ))}
        </div>
      )}
    </div>

    <article class="prose prose-invert prose-purple max-w-none font-mono">
      <slot />
    </article>

    <div class="mt-16">
      <a href="javascript:history.back()" class="font-space tracking-widest text-brand-purpleLight hover:text-brand-purple transition-colors">
        [← BACK]
      </a>
    </div>
  </main>
</BaseLayout>
